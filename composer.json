{
  "name": "pkws100/timeapp",
  "description": "Backend-Grundgeruest fuer die Baustellen- und Zeiterfassungs-App",
  "type": "project",
  "license": "GPL-2.0-or-later",
  "require": {
    "php": "^8.2",
    "ext-curl": "*",
    "ext-json": "*",
    "ext-mbstring": "*",
    "ext-pdo": "*",
    "ext-pdo_mysql": "*",
    "minishlink/web-push": "^9.0",
    "mpdf/mpdf": "^8.2",
    "phpoffice/phpspreadsheet": "^2.1",
    "robmorgan/phinx": "^0.16.6"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.3"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    },
    "files": [
      "src/Support/helpers.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit --configuration phpunit.xml.dist",
    "migrate": "phinx migrate -c phinx.php",
    "seed": "phinx seed:run -c phinx.php -s InitialReferenceSeeder",
    "bootstrap-admin": "php bin/bootstrap-admin.php"
  },
  "config": {
    "sort-packages": true
  }
}
