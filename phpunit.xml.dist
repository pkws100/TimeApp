<?xml version="1.0" encoding="UTF-8"?>
<phpunit
    bootstrap="tests/bootstrap.php"
    colors="true"
    cacheResult="false"
    beStrictAboutOutputDuringTests="true"
>
    <testsuites>
        <testsuite name="Application Test Suite">
            <directory>tests/Unit</directory>
            <directory>tests/Integration</directory>
        </testsuite>
    </testsuites>
</phpunit>

