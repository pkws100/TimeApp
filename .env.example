APP_NAME="Baustellen Zeiterfassung"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://zeiterfassung.example.invalid
APP_TIMEZONE=Europe/Berlin
APP_LOCALE=de
APP_FALLBACK_LOCALE=de

APP_PORT=18080
DOCKER_DB_DATABASE=zeiterfassung
DOCKER_DB_USERNAME=zeiterfassung
DOCKER_DB_PASSWORD=change-this-database-password
DOCKER_DB_ROOT_PASSWORD=change-this-root-password

DB_DRIVER=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=zeiterfassung
DB_USERNAME=root
DB_PASSWORD=
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci
DB_SOCKET=/run/mysqld/mysqld.sock

SESSION_NAME=zeiterfassung_session
SESSION_LIFETIME=7200

UPLOAD_DISK=local
UPLOAD_ROOT=storage/app/uploads
UPLOAD_MAX_FILESIZE=10485760

EXPORT_TEMP_PATH=storage/cache/exports
