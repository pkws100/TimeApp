APP_NAME="Baustellen Zeiterfassung"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://zeiterfassung.example.invalid
APP_TIMEZONE=Europe/Berlin
APP_LOCALE=de
APP_FALLBACK_LOCALE=de
# Generate a long random value, for example:
# php -r "echo bin2hex(random_bytes(32)), PHP_EOL;"
APP_SECRET=
# Optional dedicated key for encrypted Settings secrets. Empty means APP_SECRET is used.
SETTINGS_ENCRYPTION_KEY=

# Docker / production compose
TIMEAPP_IMAGE=timeapp-web:latest
APP_PORT=18080
PROXY_NETWORK=proxy
SCHEDULER_INTERVAL_SECONDS=300

DOCKER_DB_DATABASE=zeiterfassung
DOCKER_DB_USERNAME=zeiterfassung
DOCKER_DB_PASSWORD=replace-with-a-long-random-db-password
DOCKER_DB_ROOT_PASSWORD=replace-with-a-long-random-root-password

DB_DRIVER=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=zeiterfassung
DB_USERNAME=root
DB_PASSWORD=
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci
DB_SOCKET=/run/mysqld/mysqld.sock

SESSION_NAME=zeiterfassung_session
SESSION_LIFETIME=7200
SESSION_SECURE_COOKIE=true

UPLOAD_DISK=local
UPLOAD_ROOT=storage/app/uploads
UPLOAD_MAX_FILESIZE=33554432

EXPORT_TEMP_PATH=storage/cache/exports

# Browser push / VAPID keys. Generate real values with:
# php bin/generate-vapid-keys.php
PUSH_VAPID_PUBLIC_KEY=
PUSH_VAPID_PRIVATE_KEY=
PUSH_VAPID_SUBJECT=mailto:admin@example.invalid

# Optional map provider overrides
MAP_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png
MAP_TILE_ATTRIBUTION="&copy; OpenStreetMap-Mitwirkende"
MAP_GEOCODE_URL=https://nominatim.openstreetmap.org/search
